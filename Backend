import sqlite3
from datetime import datetime, timedelta

DB_NAME = "prestamos.db"

def conectar():
    return sqlite3.connect(DB_NAME)

def inicializar_bd():
    conexion = conectar()
    cursor = conexion.cursor()

    # Tabla clientes
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS clientes (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            nombre TEXT NOT NULL,
            telefono TEXT,
            correo TEXT,
            direccion TEXT,
            lugar_residencia TEXT,
            dia_cobro TEXT,
            frecuencia_pago TEXT
        )
    ''')

    # Tabla prestamos
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS prestamos (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            cliente_id INTEGER,
            monto REAL,
            tasa_interes REAL,
            plazo_periodos INTEGER,
            pago_por_periodo REAL,
            total_pagar REAL,
            interes_total REAL,
            fecha_inicio TEXT,
            fecha_estimada_fin TEXT,
            estado TEXT,
            FOREIGN KEY(cliente_id) REFERENCES clientes(id)
        )
    ''')

    # Tabla pagos
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS pagos (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            prestamo_id INTEGER,
            numero_periodo INTEGER,
            fecha_esperada TEXT,
            fecha_pago TEXT,
            monto_esperado REAL,
            monto_pagado REAL,
            estatus TEXT,
            adeudo_acumulado REAL,
            FOREIGN KEY(prestamo_id) REFERENCES prestamos(id)
        )
    ''')

    # Tabla capital
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS capital (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            capital_total REAL,
            capital_disponible REAL,
            deuda_dueno REAL,
            fecha_actualizacion TEXT
        )
    ''')
    
    # Inicializar capital si no existe
    cursor.execute("SELECT COUNT(*) FROM capital")
    if cursor.fetchone()[0] == 0:
        cursor.execute("INSERT INTO capital (capital_total, capital_disponible, deuda_dueno, fecha_actualizacion) VALUES (0, 0, 0, ?)", (datetime.now().strftime("%Y-%m-%d %H:%M:%S"),))

    # Tabla movimientos_capital
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS movimientos_capital (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            tipo TEXT,
            monto REAL,
            descripcion TEXT,
            fecha TEXT
        )
    ''')

    # Tabla historial_cerrados
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS historial_cerrados (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            cliente_id INTEGER,
            nombre_cliente TEXT,
            monto_prestado REAL,
            total_cobrado REAL,
            ganancia_generada REAL,
            fecha_inicio TEXT,
            fecha_cierre TEXT,
            motivo_cierre TEXT
        )
    ''')

    # Tabla ahorros
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS ahorros (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            cliente_id INTEGER,
            tasa_interes REAL,
            saldo REAL,
            fecha_apertura TEXT,
            fecha_desbloqueo TEXT,
            estado TEXT,
            FOREIGN KEY(cliente_id) REFERENCES clientes(id)
        )
    ''')

    # Tabla movimientos_ahorro
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS movimientos_ahorro (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            ahorro_id INTEGER,
            tipo TEXT,
            monto REAL,
            fecha TEXT,
            FOREIGN KEY(ahorro_id) REFERENCES ahorros(id)
        )
    ''')

    conexion.commit()
    conexion.close()

