    # Actualizar estatus a vencido si la fecha_esperada < hoy y estatus es pendiente
    hoy = datetime.now().strftime("%Y-%m-%d")
    cursor.execute("UPDATE pagos SET estatus='vencido' WHERE prestamo_id=? AND estatus='pendiente' AND fecha_esperada < ?", (prestamo_id, hoy))
    conexion.commit()
    
    cursor.execute('SELECT * FROM pagos WHERE prestamo_id=? ORDER BY numero_periodo', (prestamo_id,))
