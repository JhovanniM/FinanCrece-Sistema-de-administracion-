def crear_ahorro(cliente_id, tasa_interes):
    conexion = conectar()
    cursor = conexion.cursor()
    fecha_apertura = datetime.now()
    fecha_desbloqueo = fecha_apertura + timedelta(days=365)
    
    cursor.execute('''
        INSERT INTO ahorros (cliente_id, tasa_interes, saldo, fecha_apertura, fecha_desbloqueo, estado)
        VALUES (?, ?, 0, ?, ?, 'activo')
    ''', (cliente_id, tasa_interes, fecha_apertura.strftime("%Y-%m-%d"), fecha_desbloqueo.strftime("%Y-%m-%d")))
    conexion.commit()
    conexion.close()

def depositar_ahorro(ahorro_id, monto):
    conexion = conectar()
    cursor = conexion.cursor()
    fecha = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    
    # Insertar movimiento
    cursor.execute('INSERT INTO movimientos_ahorro (ahorro_id, tipo, monto, fecha) VALUES (?, ?, ?, ?)', (ahorro_id, 'deposito', monto, fecha))
    
    # Actualizar saldo ahorro
    cursor.execute('UPDATE ahorros SET saldo = saldo + ? WHERE id = ?', (monto, ahorro_id))
    
    # Actualizar capital (sumar al disponible y total)
    cursor.execute('SELECT capital_total, capital_disponible FROM capital WHERE id=1')
    cap = cursor.fetchone()
    total = cap[0] + monto
    disponible = cap[1] + monto
    cursor.execute('UPDATE capital SET capital_total=?, capital_disponible=?, fecha_actualizacion=? WHERE id=1', (total, disponible, fecha))
    
    conexion.commit()
    conexion.close()

# --- COBROS DEL DIA ---
def obtener_cobros_del_dia(fecha=None):
    if fecha is None:
        fecha = datetime.now().strftime("%Y-%m-%d")
        
    # Validamos vencidos
    conexion = conectar()
    cursor = conexion.cursor()
    cursor.execute("UPDATE pagos SET estatus='vencido' WHERE estatus='pendiente' AND fecha_esperada < ?", (datetime.now().strftime("%Y-%m-%d"),))
    conexion.commit()
    
    cursor.execute('''
        SELECT c.nombre, c.telefono, c.lugar_residencia, p.id, pa.id, pa.monto_esperado, pa.estatus, p.cliente_id
        FROM pagos pa
        JOIN prestamos p ON pa.prestamo_id = p.id
        JOIN clientes c ON p.cliente_id = c.id
        WHERE pa.fecha_esperada = ? OR pa.estatus = 'vencido'
    ''', (fecha,))
    
    cobros = cursor.fetchall()
    conexion.close()
    return cobros

# --- METRICAS Y GRAFICAS ---
def obtener_metricas_dashboard():
    conexion = conectar()
    cursor = conexion.cursor()
    hoy = datetime.now().strftime("%Y-%m-%d")
    
    # Cobros esperados hoy
    cursor.execute("SELECT SUM(monto_esperado) FROM pagos WHERE fecha_esperada = ? AND estatus IN ('pendiente', 'vencido')", (hoy,))
    res1 = cursor.fetchone()
    esperado_hoy = res1[0] if res1 and res1[0] else 0
    
    # Ganancias estimadas
    cursor.execute("SELECT SUM(interes_total) FROM prestamos WHERE estado='activo'")
    res2 = cursor.fetchone()
    ganancias_estimadas = res2[0] if res2 and res2[0] else 0
    
    # Préstamos activos
    cursor.execute("SELECT COUNT(*) FROM prestamos WHERE estado='activo'")
    prestamos_activos = cursor.fetchone()[0]
    
    # Deuda acumulada de clientes
    cursor.execute("SELECT SUM(adeudo_acumulado) FROM pagos WHERE estatus IN ('vencido', 'parcial', 'falta')")
    res3 = cursor.fetchone()
    deuda_clientes = res3[0] if res3 and res3[0] else 0
    
    conexion.close()
    return {
        "esperado_hoy": esperado_hoy,
        "ganancias_estimadas": ganancias_estimadas,
        "prestamos_activos": prestamos_activos,
        "deuda_clientes": deuda_clientes
    }

def obtener_datos_graficas():
    conexion = conectar()
    cursor = conexion.cursor()
    
    # 1. Capital por zona
    cursor.execute('''
        SELECT c.lugar_residencia, SUM(p.monto) 
        FROM prestamos p 
        JOIN clientes c ON p.cliente_id = c.id 
        WHERE p.estado='activo' 
        GROUP BY c.lugar_residencia
    ''')
    capital_por_zona = cursor.fetchall()
    
    # 2. Movimientos de capital (entradas vs salidas)
    cursor.execute('''
        SELECT tipo, SUM(monto) FROM movimientos_capital GROUP BY tipo
    ''')
    movimientos = cursor.fetchall()
    
    # 3. Cartera Total
    cursor.execute("SELECT SUM(monto) FROM prestamos WHERE estado='activo'")
    res_calle = cursor.fetchone()
    en_calle = res_calle[0] if res_calle and res_calle[0] else 0
    
    cursor.execute('SELECT capital_disponible FROM capital WHERE id=1')
    cap_disp = cursor.fetchone()
    disponible = cap_disp[0] if cap_disp else 0
    
    cursor.execute('SELECT SUM(saldo) FROM ahorros WHERE estado="activo"')
    ahorros = cursor.fetchone()
    deuda_ahorros = ahorros[0] if ahorros and ahorros[0] else 0
    
    caja_real = disponible - deuda_ahorros if disponible >= deuda_ahorros else 0
    cartera_total = [("En Calle (Prestado)", en_calle), ("Caja Real Mía", caja_real), ("Dinero Ahorradores", deuda_ahorros)]
    
    # 4. Crecimiento (Pagos recibidos a lo largo del tiempo)
    cursor.execute('''
        SELECT fecha_pago, SUM(monto_pagado) 
        FROM pagos 
        WHERE estatus IN ('pagado', 'parcial') 
        GROUP BY fecha_pago 
        ORDER BY fecha_pago
    ''')
    crecimiento = cursor.fetchall()
    
    conexion.close()
    return {
        "capital_por_zona": capital_por_zona,
        "movimientos": movimientos,
        "cartera_total": cartera_total,
        "crecimiento": crecimiento
    }

