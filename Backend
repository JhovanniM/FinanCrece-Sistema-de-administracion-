# --- GESTION DE CAPITAL ---
def obtener_capital():
    conexion = conectar()
    cursor = conexion.cursor()
    cursor.execute('SELECT * FROM capital WHERE id=1')
    cap = cursor.fetchone()
    
    cursor.execute('SELECT SUM(saldo) FROM ahorros WHERE estado="activo"')
    res = cursor.fetchone()
    deuda_ahorros = res[0] if res and res[0] else 0
    conexion.close()
    
    if cap:
        return (cap[0], cap[1], cap[2], cap[3], cap[4], deuda_ahorros)
    return None

def registrar_movimiento_capital(tipo, monto, descripcion):
    conexion = conectar()
    cursor = conexion.cursor()
    fecha = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    cursor.execute('''
        INSERT INTO movimientos_capital (tipo, monto, descripcion, fecha) VALUES (?, ?, ?, ?)
    ''', (tipo, monto, descripcion, fecha))
    
    # Actualizar tabla capital
    cursor.execute('SELECT capital_total, capital_disponible, deuda_dueno FROM capital WHERE id=1')
    cap = cursor.fetchone()
    total, disponible, deuda = cap[0], cap[1], cap[2]
    
    if tipo == 'entrada':
        if deuda > 0:
            if monto >= deuda:
                restante = monto - deuda
                deuda = 0
                disponible += restante
                total += restante
            else:
                deuda -= monto
        else:
            disponible += monto
            total += monto
    elif tipo == 'salida':
        if disponible >= monto:
            disponible -= monto
            total -= monto
        else:
            faltante = monto - disponible
            disponible = 0
            deuda += faltante
            total -= monto
    
    cursor.execute('''
        UPDATE capital SET capital_total=?, capital_disponible=?, deuda_dueno=?, fecha_actualizacion=? WHERE id=1
    ''', (total, disponible, deuda, fecha))
    
    conexion.commit()
    conexion.close()

def ajustar_capital_manual(nuevo_total):
    conexion = conectar()
    cursor = conexion.cursor()
    fecha = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    
    # Obtenemos capital en calle sumando todos los préstamos activos (su monto original, no los intereses)
    # Una forma más exacta es el capital total anterior - disponible.
    cursor.execute('SELECT capital_total, capital_disponible, deuda_dueno FROM capital WHERE id=1')
    cap = cursor.fetchone()
    total_ant, disponible_ant, deuda_ant = cap[0], cap[1], cap[2]
    
    capital_en_calle = total_ant - disponible_ant + deuda_ant
    
    nuevo_disponible = nuevo_total - capital_en_calle
    nueva_deuda = 0
    if nuevo_disponible < 0:
        nueva_deuda = abs(nuevo_disponible)
        nuevo_disponible = 0
        
    cursor.execute('''
        UPDATE capital SET capital_total=?, capital_disponible=?, deuda_dueno=?, fecha_actualizacion=? WHERE id=1
    ''', (nuevo_total, nuevo_disponible, nueva_deuda, fecha))
    
    cursor.execute('''
        INSERT INTO movimientos_capital (tipo, monto, descripcion, fecha) VALUES (?, ?, ?, ?)
    ''', ('ajuste', nuevo_total, 'Ajuste manual de capital total', fecha))
    
    conexion.commit()
    conexion.close()

# --- GESTION DE PRESTAMOS ---
def registrar_prestamo(cliente_id, monto, tasa_interes, plazo_periodos):
    cliente = obtener_cliente_por_id(cliente_id)
    frecuencia = cliente[7] # frecuencia_pago
    
    interes_total = monto * (tasa_interes / 100)
    total_pagar = monto + interes_total
    pago_por_periodo = total_pagar / plazo_periodos
    fecha_inicio = datetime.now()
    
    if frecuencia == 'Semanal':
        dias = plazo_periodos * 7
    else: # Mensual
        dias = plazo_periodos * 30
        
    fecha_estimada_fin = fecha_inicio + timedelta(days=dias)
    
    conexion = conectar()
    cursor = conexion.cursor()
    
    # Validar capital y registrar movimiento
    # Lo restamos usando registrar_movimiento_capital pero aquí hacemos la inserción directa para una sola transacción
    cursor.execute('SELECT capital_disponible, deuda_dueno FROM capital WHERE id=1')
    cap = cursor.fetchone()
    disponible, deuda = cap[0], cap[1]
    
    if disponible >= monto:
        disponible -= monto
    else:
        faltante = monto - disponible
        disponible = 0
        deuda += faltante
        cursor.execute("INSERT INTO movimientos_capital (tipo, monto, descripcion, fecha) VALUES (?, ?, ?, ?)", 
                       ("deuda_dueño", faltante, f"Préstamo a {cliente[1]} excede capital", fecha_inicio.strftime("%Y-%m-%d %H:%M:%S")))
        
    cursor.execute('UPDATE capital SET capital_disponible=?, deuda_dueno=?, fecha_actualizacion=? WHERE id=1', 
                   (disponible, deuda, fecha_inicio.strftime("%Y-%m-%d %H:%M:%S")))
    
    cursor.execute("INSERT INTO movimientos_capital (tipo, monto, descripcion, fecha) VALUES (?, ?, ?, ?)", 
                   ("salida", monto, f"Préstamo autorizado a {cliente[1]}", fecha_inicio.strftime("%Y-%m-%d %H:%M:%S")))
    
    cursor.execute('''
        INSERT INTO prestamos (cliente_id, monto, tasa_interes, plazo_periodos, pago_por_periodo, total_pagar, interes_total, fecha_inicio, fecha_estimada_fin, estado)
        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
    ''', (cliente_id, monto, tasa_interes, plazo_periodos, pago_por_periodo, total_pagar, interes_total, fecha_inicio.strftime("%Y-%m-%d"), fecha_estimada_fin.strftime("%Y-%m-%d"), 'activo'))
    
    prestamo_id = cursor.lastrowid
    
    # Generar pagos esperados
    fecha_esperada = fecha_inicio
    for i in range(1, plazo_periodos + 1):
        if frecuencia == 'Semanal':
            fecha_esperada += timedelta(days=7)
        else:
            fecha_esperada += timedelta(days=30)
            
        cursor.execute('''
            INSERT INTO pagos (prestamo_id, numero_periodo, fecha_esperada, fecha_pago, monto_esperado, monto_pagado, estatus, adeudo_acumulado)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?)
        ''', (prestamo_id, i, fecha_esperada.strftime("%Y-%m-%d"), None, pago_por_periodo, 0, 'pendiente', 0))
    
    conexion.commit()
    conexion.close()

