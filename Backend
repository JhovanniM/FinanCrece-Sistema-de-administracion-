def registrar_pago(pago_id, monto_recibido, estatus, adeudo=0):
    conexion = conectar()
    cursor = conexion.cursor()
    fecha_pago = datetime.now().strftime("%Y-%m-%d")
    
    cursor.execute('SELECT prestamo_id, monto_esperado FROM pagos WHERE id=?', (pago_id,))
    res = cursor.fetchone()
    if not res: return
    prestamo_id, monto_esperado = res
    
    cursor.execute('''
        UPDATE pagos SET fecha_pago=?, monto_pagado=?, estatus=?, adeudo_acumulado=? WHERE id=?
    ''', (fecha_pago, monto_recibido, estatus, adeudo, pago_id))
    
    # Registrar entrada de capital
    if monto_recibido > 0:
        cursor.execute("INSERT INTO movimientos_capital (tipo, monto, descripcion, fecha) VALUES (?, ?, ?, ?)", 
                       ("entrada", monto_recibido, f"Pago recibido del préstamo #{prestamo_id}", fecha_pago))
        
        cursor.execute('SELECT capital_total, capital_disponible, deuda_dueno FROM capital WHERE id=1')
        cap = cursor.fetchone()
        total, disponible, deuda = cap[0], cap[1], cap[2]
        if deuda > 0:
            if monto_recibido >= deuda:
                restante = monto_recibido - deuda
                deuda = 0
                disponible += restante
                total += restante # La ganancia/recuperacion aumenta el total
            else:
                deuda -= monto_recibido
        else:
            disponible += monto_recibido
            total += monto_recibido # Incrementa capital total por interés
            
        cursor.execute('UPDATE capital SET capital_total=?, capital_disponible=?, deuda_dueno=?, fecha_actualizacion=? WHERE id=1', 
                       (total, disponible, deuda, fecha_pago))
    
    # Verificar si el préstamo se ha concluido
    cursor.execute('SELECT COUNT(*) FROM pagos WHERE prestamo_id=? AND estatus IN ("pendiente", "vencido", "falta")', (prestamo_id,))
    pendientes = cursor.fetchone()[0]
    
    if pendientes == 0:
        cursor.execute('UPDATE prestamos SET estado="concluido" WHERE id=?', (prestamo_id,))
        
    conexion.commit()
    conexion.close()
    
def concluir_prestamo_historial(prestamo_id, motivo):
    # Guarda en historial_cerrados y borra registros
    conexion = conectar()
    cursor = conexion.cursor()
    
    cursor.execute('SELECT cliente_id, monto, total_pagar, interes_total, fecha_inicio FROM prestamos WHERE id=?', (prestamo_id,))
    p_data = cursor.fetchone()
    if not p_data: return
    cliente_id, monto, total_pagar, interes_total, fecha_inicio = p_data
    
    cursor.execute('SELECT nombre FROM clientes WHERE id=?', (cliente_id,))
    c_data = cursor.fetchone()
    nombre_cliente = c_data[0] if c_data else "Desconocido"
    
    cursor.execute('SELECT SUM(monto_pagado) FROM pagos WHERE prestamo_id=?', (prestamo_id,))
    pagos_data = cursor.fetchone()
    total_cobrado = pagos_data[0] if pagos_data[0] else 0
    ganancia_generada = total_cobrado - monto
    fecha_cierre = datetime.now().strftime("%Y-%m-%d")
    
    cursor.execute('''
        INSERT INTO historial_cerrados (cliente_id, nombre_cliente, monto_prestado, total_cobrado, ganancia_generada, fecha_inicio, fecha_cierre, motivo_cierre)
        VALUES (?, ?, ?, ?, ?, ?, ?, ?)
    ''', (cliente_id, nombre_cliente, monto, total_cobrado, ganancia_generada, fecha_inicio, fecha_cierre, motivo))
    
    # Eliminar registros
    cursor.execute('DELETE FROM pagos WHERE prestamo_id=?', (prestamo_id,))
    cursor.execute('DELETE FROM prestamos WHERE id=?', (prestamo_id,))
    
    conexion.commit()
    conexion.close()

